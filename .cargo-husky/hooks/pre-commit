#!/bin/sh
# Installed into .git/hooks/ by cargo-husky on `cargo test`.
# Fast checks that gate every commit (analogue of eval-runner's typecheck + lint-staged).
set -e

echo "[pre-commit] cargo fmt --check"
cargo fmt --all -- --check

echo "[pre-commit] cargo clippy"
cargo clippy --all-targets --all-features -- -D warnings
